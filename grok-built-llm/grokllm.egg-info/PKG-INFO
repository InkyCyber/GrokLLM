│   ├── tokenizer.py      # Character-level
│   ├── generate.py       # Sampling strategies
│   ├── config.py
│   └── ...
├── train.py              # The actual training loop
├── app.py                # FastAPI server
├── web/index.html        # The entire beautiful frontend
